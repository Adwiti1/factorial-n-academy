rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function existingRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function userRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && existingRole() == role;
    }

    function teacherOwnsClassroomData(classroomData) {
      return userRole('teacher') && classroomData.teacherId == request.auth.uid;
    }

    function ownsClassroom(classroomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/classrooms/$(classroomId))
        && teacherOwnsClassroomData(get(/databases/$(database)/documents/classrooms/$(classroomId)).data);
    }

    function classroomData(classroomId) {
      return get(/databases/$(database)/documents/classrooms/$(classroomId)).data;
    }

    function isClassroomStudent(classroomId) {
      return userRole('student')
        && exists(/databases/$(database)/documents/classrooms/$(classroomId))
        && classroomData(classroomId).studentIds is list
        && request.auth.uid in classroomData(classroomId).studentIds;
    }

    function canReadClassroom(classroomId) {
      return ownsClassroom(classroomId) || isClassroomStudent(classroomId);
    }

    function hasClassroomId(data) {
      return data.classroomId is string;
    }

    function assignmentBelongsToClassroom(assignmentId, classroomId) {
      return assignmentId is string
        && exists(/databases/$(database)/documents/assignments/$(assignmentId))
        && get(/databases/$(database)/documents/assignments/$(assignmentId)).data.classroomId == classroomId;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.role in ['student', 'teacher'];
      allow read: if isOwner(userId);
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    match /teachers/{teacherId} {
      allow create, read, update: if isOwner(teacherId) && userRole('teacher');
      allow delete: if false;
    }

    match /students/{studentId} {
      allow create, read, update: if isOwner(studentId) && userRole('student');
      allow delete: if false;
    }

    match /classrooms/{classroomId} {
      allow create: if userRole('teacher')
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.studentIds is list;
      allow read: if (userRole('teacher')
          && resource.data.teacherId == request.auth.uid)
        || (userRole('student')
          && request.auth.uid in resource.data.studentIds);
      allow update, delete: if ownsClassroom(classroomId);
      allow update: if userRole('student')
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['studentIds', 'students', 'updatedAt'])
        && !(request.auth.uid in resource.data.studentIds)
        && request.auth.uid in request.resource.data.studentIds
        && request.resource.data.studentIds.hasAll(resource.data.studentIds)
        && request.resource.data.studentIds.size() == resource.data.studentIds.size() + 1
        && request.resource.data.students == request.resource.data.studentIds.size();
    }

    match /classroomJoinCodes/{joinCode} {
      allow create: if userRole('teacher')
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.classroomId is string;
      allow read: if userRole('student');
      allow delete: if userRole('teacher')
        && resource.data.teacherId == request.auth.uid;
      allow update: if false;
    }

    match /modules/{moduleId} {
      allow create: if userRole('teacher')
        && hasClassroomId(request.resource.data)
        && ownsClassroom(request.resource.data.classroomId);
      allow read: if hasClassroomId(resource.data) && canReadClassroom(resource.data.classroomId);
      allow update, delete: if hasClassroomId(resource.data) && ownsClassroom(resource.data.classroomId);
    }

    match /assignments/{assignmentId} {
      allow create: if userRole('teacher')
        && hasClassroomId(request.resource.data)
        && ownsClassroom(request.resource.data.classroomId);
      allow read: if hasClassroomId(resource.data) && canReadClassroom(resource.data.classroomId);
      allow update, delete: if hasClassroomId(resource.data) && ownsClassroom(resource.data.classroomId);
    }

    match /quizzes/{quizId} {
      allow create: if userRole('teacher')
        && hasClassroomId(request.resource.data)
        && ownsClassroom(request.resource.data.classroomId);
      allow read: if hasClassroomId(resource.data) && canReadClassroom(resource.data.classroomId);
      allow update, delete: if hasClassroomId(resource.data) && ownsClassroom(resource.data.classroomId);
    }

    match /submissions/{submissionId} {
      allow create: if userRole('student')
        && hasClassroomId(request.resource.data)
        && request.resource.data.assignmentId is string
        && request.resource.data.studentId == request.auth.uid
        && isClassroomStudent(request.resource.data.classroomId)
        && assignmentBelongsToClassroom(
          request.resource.data.assignmentId,
          request.resource.data.classroomId
        );
      allow read: if userRole('student')
        && resource.data.studentId == request.auth.uid;
      allow read: if userRole('teacher')
        && hasClassroomId(resource.data)
        && ownsClassroom(resource.data.classroomId);
      allow update: if hasClassroomId(resource.data) && ownsClassroom(resource.data.classroomId);
      allow delete: if false;
    }

    match /analytics/{classroomId} {
      allow read: if ownsClassroom(classroomId);
      allow create, update: if ownsClassroom(classroomId)
        && request.resource.data.teacherId == request.auth.uid;
      allow delete: if false;
    }
  }
}
